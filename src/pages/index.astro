---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import WhatWeDo from "../components/WhatWeDo.astro";
import WhyUs from "../components/WhyUs.astro";
import AtmosphericBreak from "../components/AtmosphericBreak.astro";
import WorkGrid from "../components/WorkGrid.astro";
import InsightsList from "../components/InsightsList.astro";
import Founder from "../components/Founder.astro";
import FooterCta from "../components/FooterCta.astro";

const posts = (await getCollection("insights"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 4);
---

<Base path="/">
  <Hero />
  <WhatWeDo />
  <WhyUs />
  <AtmosphericBreak
    src="/atmos/work.jpg"
    alt="Telecom infrastructure — the production systems behind Innovation Ways' work"
    eyebrow="Built in production"
    heading="Infrastructure that has to be right the first time"
    lead="Two decades on systems where a billing run or a settlement can't be re-run — that discipline is what Innovation Ways brings to applied AI."
  />
  <WorkGrid />
  <InsightsList posts={posts} />
  <Founder />
  <FooterCta />
</Base>
