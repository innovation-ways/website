---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  /** Path of the current page, e.g. "/work" — used for the canonical URL. */
  path?: string;
}

const {
  title = "Innovation Ways — Telecom BSS engineering, now building applied AI",
  description =
    "Innovation Ways is a Telecom BSS consultancy — two decades of mission-critical billing systems at scale — now bringing that production discipline to AI, building in the open.",
  path = "/",
} = Astro.props;

const site = "https://innovation-ways.com";
const canonical = new URL(path, site).href;
const ogImage = new URL("/og-image.png", site).href;
const logoImage = new URL("/logo.png", site).href;

const orgJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Innovation Ways",
  url: site,
  logo: logoImage,
  founder: { "@type": "Person", name: "Sérgio Gaspar" },
  foundingLocation: "Lisbon, Portugal",
  sameAs: ["https://github.com/innovation-ways"],
  description,
};
const siteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Innovation Ways",
  url: site,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Apply stored theme before paint (no flash). Default follows the OS. -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem("theme");
          if (t === "dark" || t === "light") {
            document.documentElement.dataset.theme = t;
          }
        } catch (e) {}
      })();
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="generator" content={Astro.generator} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Open Graph / social -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Innovation Ways" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Fonts: Space Grotesk (display) + Inter (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400..700&family=Space+Grotesk:wght@400..700&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(siteJsonLd)} />
  </head>
  <body class="min-h-screen flex flex-col">
    <Nav path={path} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
