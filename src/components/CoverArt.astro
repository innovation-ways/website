---
// Deterministic abstract "constellation" cover art — a node/edge motif (fitting for an
// AI-orchestration company). Same seed → same image. Pure SVG, theme-token colours, no stock.
interface Props {
  seed: string;
  variant?: "banner" | "thumb";
  class?: string;
}
const { seed, variant = "banner", class: className = "" } = Astro.props;

// Seeded PRNG (mulberry32) from a string hash — deterministic per seed.
function makeRand(str: string): () => number {
  let h = 1779033703 ^ str.length;
  for (let i = 0; i < str.length; i++) {
    h = Math.imul(h ^ str.charCodeAt(i), 3432918353);
    h = (h << 13) | (h >>> 19);
  }
  let a = h >>> 0;
  return () => {
    a |= 0;
    a = (a + 0x6d2b79f5) | 0;
    let t = Math.imul(a ^ (a >>> 15), 1 | a);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}

const rand = makeRand(seed);
const W = 400;
const H = variant === "thumb" ? 300 : 180;
const count = 12 + Math.floor(rand() * 6);

const nodes = Array.from({ length: count }, () => ({
  x: 12 + rand() * (W - 24),
  y: 12 + rand() * (H - 24),
  r: 1.6 + rand() * 3.4,
}));

// Connect each node to its 1–2 nearest neighbours.
const edges: [number, number][] = [];
for (let i = 0; i < nodes.length; i++) {
  const near = nodes
    .map((n, j) => ({ j, d: (n.x - nodes[i].x) ** 2 + (n.y - nodes[i].y) ** 2 }))
    .filter((o) => o.j !== i)
    .sort((a, b) => a.d - b.d);
  const k = 1 + Math.floor(rand() * 2);
  for (let m = 0; m < k; m++) if (near[m]) edges.push([i, near[m].j]);
}
const accentNode = Math.floor(rand() * nodes.length);
---

<svg
  class={className}
  viewBox={`0 0 ${W} ${H}`}
  preserveAspectRatio="xMidYMid slice"
  role="img"
  aria-hidden="true"
  xmlns="http://www.w3.org/2000/svg"
>
  <rect width={W} height={H} fill="var(--color-surface)"></rect>
  {
    edges.map(([a, b]) => (
      <line
        x1={nodes[a].x}
        y1={nodes[a].y}
        x2={nodes[b].x}
        y2={nodes[b].y}
        stroke="var(--color-accent)"
        stroke-opacity="0.22"
        stroke-width="1"
      />
    ))
  }
  {
    nodes.map((n, i) => (
      <circle
        cx={n.x}
        cy={n.y}
        r={i === accentNode ? n.r + 1.5 : n.r}
        fill="var(--color-accent)"
        fill-opacity={i === accentNode ? "0.9" : "0.4"}
      />
    ))
  }
</svg>
