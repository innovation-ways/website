---
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"work">;
}
const { entry } = Astro.props;
const { name, tagline, tags, status } = entry.data;
---

<a
  href={`/work/${entry.id}`}
  class="group flex flex-col rounded-xl border border-line bg-paper p-6 transition-colors hover:border-accent"
>
  <div class="flex items-center justify-between gap-3">
    <h3 class="font-display text-lg font-semibold text-ink">{name}</h3>
    <span
      class:list={[
        "shrink-0 rounded-full px-2.5 py-1 text-xs font-medium",
        status === "oss"
          ? "bg-accent/10 text-accent-strong"
          : "bg-surface text-muted",
      ]}
    >
      {status === "oss" ? "Open source" : "Client engagement"}
    </span>
  </div>

  <p class="mt-3 flex-1 text-sm text-muted">{tagline}</p>

  <ul class="mt-5 flex flex-wrap gap-2">
    {
      tags.map((t) => (
        <li class="rounded-md border border-line px-2 py-1 text-xs text-muted">
          {t}
        </li>
      ))
    }
  </ul>

  <span
    class="mt-5 text-sm font-medium text-accent-strong transition-transform group-hover:translate-x-0.5"
  >
    Learn more →
  </span>
</a>
